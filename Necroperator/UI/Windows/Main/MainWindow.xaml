<Window x:Class="Necroperator.UI.Windows.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Necroperator"
        xmlns:converter="clr-namespace:Necroperator.UI.Converters"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
	    Width="900" Height="600"
	    MinWidth="450" MinHeight="300"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        AllowsTransparency="True"
        Background="Black"
        Title="Necroperator"
        DataContext="{Binding RelativeSource={RelativeSource Self}}"
        Loaded="OnLoaded">
    
    <Window.Resources>
        <ResourceDictionary>
            <converter:BooleanNegativeConverter x:Key="BooleanNegativeConverter" />
            <converter:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converter:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter" />
            
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI/Windows/Main/MainWindowStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Image Name="Image_Banner" Source="/Resources/banner.png" Stretch="UniformToFill" Opacity="0.25" />

        <DockPanel Background="Transparent">
            <!--Title bar-->
            <Grid Background="#A0000000" DockPanel.Dock="Top" MouseDown="Titlebar_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="Necroperator" HorizontalAlignment="Center" Style="{StaticResource Title}"/>
                <Button Grid.Column="1" Style="{StaticResource ImageButton}" Click="ButtonClose_Click">
                    <Image Source="/Resources/icon_close.png"/>
                </Button>
            </Grid>
            
            <!--Save locations-->
            <Grid Margin="8" DockPanel.Dock="Top" IsEnabled="{Binding IsRunning, Converter={StaticResource BooleanNegativeConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Column="0" Text="Save location:" VerticalAlignment="Center" Style="{StaticResource Label}"/>
                <TextBox Grid.Column="1" Name="TextBox_SaveLocation" Text="{Binding SaveLocation, Mode=TwoWay}" Margin="5,0,5,0"/>
                <Button Grid.Column="2" ToolTip="Browse" Style="{StaticResource ImageButton}" Click="ButtonBrowse_Click">
                    <Image Source="/Resources/icon_browse.png"/>
                </Button>
            </Grid>

            <!--Controls-->
            <Grid Margin="8" DockPanel.Dock="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Button Grid.Column="0" ToolTip="Start" Style="{StaticResource ImageButton}" IsEnabled="{Binding IsRunning, Converter={StaticResource BooleanNegativeConverter}}" Click="ButtonStart_Click">
                    <Image Source="/Resources/icon_start.png"/>
                </Button>
                <Button Grid.Column="1" ToolTip="Stop" Style="{StaticResource ImageButton}" IsEnabled="{Binding IsRunning}" Click="ButtonStop_Click">
                    <Image Source="/Resources/icon_stop.png"/>
                </Button>

                <TextBlock Grid.Column="2" Margin="8" VerticalAlignment="Center" Text="Stopped" Style="{StaticResource Status_Negative}" Visibility="{Binding IsRunning, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                <TextBlock Grid.Column="2" Margin="8" VerticalAlignment="Center" Text="Running" Style="{StaticResource Status_Positive}" Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <Button Grid.Column="4" ToolTip="Create Backup Manually" Style="{StaticResource ImageButton}" Click="ButtonManualSave_Click">
                    <Image Source="/Resources/icon_save.png"/>
                </Button>

                <Button Grid.Column="5" ToolTip="Refresh" Style="{StaticResource ImageButton}" Click="ButtonRefresh_Click">
                    <Image Source="/Resources/icon_refresh.png"/>
                </Button>
            </Grid>

            <!--Snapshots-->
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" CanContentScroll="True" Margin="8" DockPanel.Dock="Bottom">
                <ItemsControl ItemsSource="{Binding Snapshots}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Style="{StaticResource Snapshot_Container}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Style="{StaticResource Snapshot_Row}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="24" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Margin="8 0 0 0" Grid.Column="0" Style="{StaticResource Snapshot_Text_Timestamp}" Text="{Binding Timestamp, StringFormat=HH\\:mm\\:ss}" />
                                <TextBlock Grid.Column="1" Style="{StaticResource Snapshot_Text_Name}"  Text="{Binding FileHash}" />

                                <Button Grid.Column="2" ToolTip="Restore" Style="{StaticResource ImageButton}" Click="ButtonSnapshotRestore_Click">
                                    <Image Source="/Resources/icon_restore.png"/>
                                </Button>

                                <Button Margin="0 0 8 0" Grid.Column="3" ToolTip="Delete" Style="{StaticResource ImageButton}" Click="ButtonSnapshotDelete_Click">
                                    <Image Source="/Resources/icon_delete.png"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</Window>
